# 텍스트 파일 줄바꿈을 LF로 통일
* text=auto eol=lf

# Windows 전용 스크립트
*.bat text eol=crlf
*.cmd text eol=crlf

# Unity YAML 텍스트 파일
*.asset text eol=lf
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.asmdef text eol=lf
*.shadergraph text eol=lf

# 바이너리 파일
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.psd binary
*.fbx binary
*.dll binary
*.wav binary
*.mp3 binary
*.ogg binary